rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tourists/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /incidents/{incidentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == resource.data.reporter_id ||
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'police']
      );
    }
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.user_id;
    }
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.is_admin == true;
    }
  }
}
