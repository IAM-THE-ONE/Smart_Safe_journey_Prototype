# Django settings
SECRET_KEY=change-me-in-production
DEBUG=True

# Google OAuth Client ID (same as VITE_GOOGLE_CLIENT_ID in frontend/.env)
# Required for Google Sign-In to work
GOOGLE_CLIENT_ID=

# Email settings (for password reset)
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# For development without email, leave these blank — reset link appears in UI
